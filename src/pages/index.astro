---
import Layout from '../layouts/Layout.astro';
import IconExternalLink from '../components/IconExternalLink.astro';
---

<Layout title="Matthew Campagna" description="Senior frontend engineer and co-founder with nearly twenty years of experience building and shipping software, from publishing tools for professional photographers to AI-native collaboration platforms.">
  <div class="container">

    <section class="intro">
      <h1>Matthew Campagna</h1>
      <p class="title">Senior Frontend Engineer</p>
      <p class="bio">Senior frontend engineer and co-founder with nearly twenty years of experience building and shipping software, from publishing tools for professional photographers to AI-native collaboration platforms. My background in photography and visual design shapes how I approach interfaces: I care about usability, presentation, and the relationship between technology and the people who use it.</p>
      <div class="links">
        <a href="https://github.com/mjcampagna" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://www.linkedin.com/in/mjcampagna" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="https://www.npmjs.com/~slithy" target="_blank" rel="noopener noreferrer">npm</a>
        <a href="/Campagna, Matthew - Resume (202607).pdf" target="_blank" rel="noopener noreferrer">Résumé</a>
      </div>
    </section>

    <section class="work">
      <h2>Professional Experience</h2>
      <ul>
        <li>
          <a href="https://glue.ai" target="_blank" rel="noopener noreferrer">Glue <IconExternalLink /></a>
          <p class="meta">Senior Frontend Engineer · 2022–2026</p>
          <p>Built and shaped the frontend of an AI-native collaboration platform on a lean engineering team. Led development of flagship experiences including the conversational AI interface, unified inbox, and threads view, while designing core architecture and driving significant performance improvements.</p>
        </li>
        <li>
          <a href="https://theturninggate.net" target="_blank" rel="noopener noreferrer">The Turning Gate <IconExternalLink /></a>
          <p class="meta">Founder & Software Engineer · 2007–Present</p>
          <p>Co-founded an independent software company and led frontend engineering, UX, and product strategy across a portfolio of publishing tools for professional photographers spanning nearly twenty years.</p>
        </li>
        <li>
          <a href="https://joe.coffee/" target="_blank" rel="noopener noreferrer">Joe Coffee <IconExternalLink /></a>
          <p class="meta">Principal Frontend Engineer · 2021–2022</p>
          <p>Led frontend architecture for a ground-up rebuild of the consumer ordering and loyalty platform, serving as the primary frontend technical partner from concept through launch.</p>
        </li>
        <li>
          <a href="https://www.agero.com/technology-partnerships/swoop" target="_blank" rel="noopener noreferrer">Swoop <IconExternalLink /></a>
          <p class="meta">Senior Software Engineer · 2018–2021</p>
          <p>Built customer-facing features for a web-based roadside dispatch platform using React and TypeScript, contributing to frontend architecture and ongoing application modernization.</p>
        </li>
      </ul>
      <a href="/Campagna, Matthew - Resume (202607).pdf" target="_blank" rel="noopener noreferrer" class="resume-link">Full résumé ↗</a>
    </section>

    <section class="work">
      <h2>Independent Work</h2>
      <ul>
        <li>
          <a href="/work/backlight">Backlight</a>
          <p>A commercial publishing platform for professional photographers, evolved over more than a decade through major changes in browsers, responsive design, and photography workflows.</p>
        </li>
        <li>
          <a href="/work/kiln">Kiln</a>
          <p>A cross-platform Electron application for photographers built around modular workspaces, reusable widgets, and full keyboard accessibility. Includes a command palette, persistent layouts, image export pipelines, and local and remote file management.</p>
        </li>
        <li>
          <a href="/work/tessera">Tessera</a>
          <p>An image editor that reconstructs photographs from geometric primitives using mathematical algorithms rather than AI.</p>
        </li>
      </ul>
    </section>

    <section class="work">
      <h2>Selected Packages</h2>
      <ul>
        <li>
          <a href="https://www.npmjs.com/package/@slithy/react-tessera-gallery" target="_blank" rel="noopener noreferrer">react-tessera-gallery <IconExternalLink /></a>
          <p>A React component for justified gallery layouts, using optimal line-breaking to distribute images across rows without clipping or distortion.</p>
        </li>
        <li>
          <a href="https://www.npmjs.com/package/@slithy/modal-kit" target="_blank" rel="noopener noreferrer">modal-kit <IconExternalLink /></a>
          <p>Headless React modal components — accessible behavior and focus management without prescribed styles.</p>
        </li>
      </ul>
    </section>

  </div>
</Layout>

<style>
  .container {
    max-width: 680px;
    margin: 0 auto;
    padding: 5rem 2rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .intro h1 {
    font-size: var(--text-4xl);
    margin-bottom: 0.25rem;
  }

  .intro .title {
    font-size: var(--text-base);
    color: var(--color-muted);
    margin-bottom: 2rem;
  }

  .intro .bio {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-muted);
    max-width: 56ch;
  }

  .links {
    display: flex;
    gap: 2rem;
    margin-top: 1.5rem;
  }

  .links a {
    font-size: var(--text-sm);
    color: var(--color-muted);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .links a:hover {
    color: var(--color-text);
  }

  .work h2 {
    font-size: var(--text-xs);
    font-family: var(--font-sans);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .work ul {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .work li a {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    text-decoration: none;
    color: var(--color-text);
  }

  .work li a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .work li p {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-top: 0.25rem;
  }

  .resume-link {
    display: inline-block;
    margin-top: 1.5rem;
    font-size: var(--text-sm);
    color: var(--color-muted);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .resume-link:hover {
    color: var(--color-text);
  }

  .work li .meta {
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.02em;
    margin-top: 0.2rem;
  }
</style>
